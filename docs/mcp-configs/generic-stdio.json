{
  "mcpServers": {
    "mnemos": {
      "command": "python",
      "args": [
        "-m",
        "mnemos.mcp_server"
      ],
      "env": {
        "MNEMOS_LLM_PROVIDER": "mock",
        "MNEMOS_EMBEDDING_PROVIDER": "simple",
        "MNEMOS_STORE_TYPE": "sqlite",
        "MNEMOS_SQLITE_PATH": ".mnemos/memory.db"
      }
    }
  }
}
